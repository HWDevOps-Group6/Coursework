		"passport": "^0.7.0",
		"passport-google-oauth20": "^2.0.0"
	},
	"devDependencies": {
		"chai": "^4.3.0",
		"mongodb-memory-server": "^10.2.3",
		"mocha": "^10.0.0",
		"mochawesome": "^7.1.4",
		"nodemon": "^3.0.2",
