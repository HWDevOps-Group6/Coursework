	"description": "Authentication microservice - register, login, Google OAuth, JWT issuance",
	"main": "src/server.js",
	"scripts": {
		"start": "node src/server.js",
		"dev": "nodemon src/server.js",
		"test": "mocha --reporter mochawesome test/*.test.js",
