def changedPaths() {
    def paths = []

    currentBuild.changeSets.each { changeSet ->
        changeSet.items.each { entry ->
            entry.affectedFiles.each { file ->
                paths << file.path
            }
        }
    }

    return paths.unique()
}

def hasPathChange(List prefixes) {
    def paths = changedPaths()

    if (!paths || paths.isEmpty()) {
        return true
    }

    return paths.any { path ->
        prefixes.any { prefix ->
            path == prefix || path.startsWith(prefix)
        }
    }
}

def authServiceChanged() {
    return hasPathChange(['services/auth-service/'])
}

def diagnosticsServiceChanged() {
    return hasPathChange(['services/diagnostics-vitals-service/'])
}

def patientServiceChanged() {
    return hasPathChange(['services/patient-registration-service/'])
}

def gatewayChanged() {
    return hasPathChange(['Dockerfile.gateway', 'src/', 'shared/'])
}

def applicationChanged() {
    return gatewayChanged() || authServiceChanged() || diagnosticsServiceChanged() || patientServiceChanged()
}

pipeline {
    tools {
        nodejs 'NodeJS' 
    }
    agent any

    environment {
        REGISTRY = "hwudevopsregistry-e9a8dkdbanfebbhh.azurecr.io"
        ACR_CREDS = credentials('azure-reg-creds')
        K8S_NAMESPACE = 'coursework'
        K8S_APP_SECRET_NAME = 'coursework-app-secrets'
        K8S_REGISTRY_SECRET = 'acr-registry'
    }

    stages {
        stage('Login & Cleanup') {
            steps {
                sh '''#!/bin/sh
                printf '%s' "$ACR_CREDS_PSW" | docker login "$REGISTRY" -u "$ACR_CREDS_USR" --password-stdin
                '''
            }
        }

        // --- TEST: AUTH SERVICE ---
        stage('Test Auth Service') {
            when {
                expression {
                    authServiceChanged()
                }
            }
            steps {
                catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                    dir('services/auth-service') {
                        sh 'npm install'
                        sh 'npm test'
                    }
                }
            }
            post {
                failure {
                    echo 'Auth Service tests failed! Check the logs above for details.'
                }
            }
        }

        // --- TEST: DIAGNOSTICS & VITALS ---
        stage('Test Diagnostics Service') {
            when {
                expression {
                    diagnosticsServiceChanged()
                }
            }
            steps {
                catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                    dir('services/diagnostics-vitals-service') {
                        sh 'npm install'
                        sh 'npm test'
                    }
                }
            }
            post {
                failure {
                    echo 'Diagnostics Service tests failed! Check the logs above for details.'
                }
            }
        }

        // --- TEST: PATIENT REGISTRATION ---
        stage('Test Patient Service') {
            when {
                expression {
                    patientServiceChanged()
                }
            }
            steps {
                catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                    dir('services/patient-registration-service') {
                        sh 'npm install'
                        sh 'npm test'
                    }
                }
            }
            post {
                failure {
                    echo 'Patient Service tests failed! Check the logs above for details.'
                }
            }
        }

        // --- STAGE: API GATEWAY ---
        stage('Build API Gateway') {
            when {
                expression {
                    gatewayChanged()
                }
            }
            steps {
                sh "docker build -f Dockerfile.gateway -t ${REGISTRY}/gateway:${env.BUILD_NUMBER} -t ${REGISTRY}/gateway:latest ."
                sh "docker push ${REGISTRY}/gateway:${env.BUILD_NUMBER}"
                sh "docker push ${REGISTRY}/gateway:latest"
            }
        }

        // --- STAGE: AUTH SERVICE ---
        stage('Build Auth Service') {
            when {
                expression {
                    authServiceChanged()
                }
            }
            steps {
                sh "docker build -f services/auth-service/Dockerfile -t ${REGISTRY}/auth-service:${env.BUILD_NUMBER} -t ${REGISTRY}/auth-service:latest ."
                sh "docker push ${REGISTRY}/auth-service:${env.BUILD_NUMBER}"
                sh "docker push ${REGISTRY}/auth-service:latest"
            }
        }

        // --- STAGE: DIAGNOSTICS & VITALS ---
        stage('Build Diagnostics Service') {
            when {
                expression {
                    diagnosticsServiceChanged()
                }
            }
            steps {
                sh "docker build -f services/diagnostics-vitals-service/Dockerfile -t ${REGISTRY}/vitals-service:${env.BUILD_NUMBER} -t ${REGISTRY}/vitals-service:latest ."
                sh "docker push ${REGISTRY}/vitals-service:${env.BUILD_NUMBER}"
                sh "docker push ${REGISTRY}/vitals-service:latest"
            }
        }

        // --- STAGE: PATIENT REGISTRATION ---
        stage('Build Patient Service') {
            when {
                expression {
                    patientServiceChanged()
                }
            }
            steps {
                sh "docker build -f services/patient-registration-service/Dockerfile -t ${REGISTRY}/patient-service:${env.BUILD_NUMBER} -t ${REGISTRY}/patient-service:latest ."
                sh "docker push ${REGISTRY}/patient-service:${env.BUILD_NUMBER}"
                sh "docker push ${REGISTRY}/patient-service:latest"
            }
        }

        // --- STAGE: SONARCLOUD ---
        stage('SonarCloud Analysis') {
            when {
                expression {
                    applicationChanged()
                }
            }
            steps {
                script {
                    dir('services/auth-service') {
                        sh 'npm install'
                        sh 'npm run test:coverage'
                    }
                    dir('services/diagnostics-vitals-service') {
                        sh 'npm install'
                        sh 'npm run test:coverage'
                    }
                    dir('services/patient-registration-service') {
                        sh 'npm install'
                        sh 'npm run test:coverage'
                    }

                    sh '''#!/bin/sh
                    set -e
                    test -f services/auth-service/coverage/lcov.info
                    test -f services/diagnostics-vitals-service/coverage/lcov.info
                    test -f services/patient-registration-service/coverage/lcov.info
                    ls -l services/auth-service/coverage/lcov.info
                    ls -l services/diagnostics-vitals-service/coverage/lcov.info
                    ls -l services/patient-registration-service/coverage/lcov.info
                    '''

                    def scannerHome = tool 'sonar-scanner'
                    withSonarQubeEnv('SonarCloud') {
                        sh """
                        ${scannerHome}/bin/sonar-scanner \
                        -Dsonar.projectBaseDir=${WORKSPACE} \
                        -Dsonar.organization=hwdevops-group6 \
                        -Dsonar.projectKey=HWDevOps-Group6_Coursework \
                        -Dsonar.projectName=healthcare-management-system \
                        -Dsonar.verbose=true \
                        -Dsonar.sources=src,shared,services/auth-service/src,services/diagnostics-vitals-service/server.js,services/diagnostics-vitals-service/config,services/diagnostics-vitals-service/middleware,services/diagnostics-vitals-service/models,services/diagnostics-vitals-service/services,services/patient-registration-service/src \
                        -Dsonar.tests=services/auth-service/test,services/diagnostics-vitals-service/test,services/patient-registration-service/test \
                        -Dsonar.exclusions=**/node_modules/**,**/mochawesome-report/**,**/coverage/**,**/.nyc_output/**,**/.dockerignore,**/build-wrapper-dump.json \
                        -Dsonar.javascript.lcov.reportPaths=${WORKSPACE}/services/auth-service/coverage/lcov.info,${WORKSPACE}/services/diagnostics-vitals-service/coverage/lcov.info,${WORKSPACE}/services/patient-registration-service/coverage/lcov.info
                        """
                    }
                }
            }
        }

        stage('Deploy to Kubernetes') {
            when {
                expression {
                    hasPathChange([
                        'Dockerfile.gateway',
                        'src/',
                        'shared/',
                        'services/auth-service/',
                        'services/diagnostics-vitals-service/',
                        'services/patient-registration-service/',
                        'k8s/',
                        'Jenkinsfile',
                        'jenkinsfile',
                    ])
                }
            }
            steps {
                script {
                    def kubectlCmd = sh(
                        script: '''#!/bin/bash
                        set -euo pipefail

                        if command -v kubectl >/dev/null 2>&1; then
                            command -v kubectl
                            exit 0
                        fi

                        command -v curl >/dev/null 2>&1 || {
                            echo '[K8S] curl is required to download kubectl' >&2
                            exit 1
                        }

                        BIN_DIR="$WORKSPACE/.jenkins/bin"
                        mkdir -p "$BIN_DIR"

                        OS="$(uname | tr '[:upper:]' '[:lower:]')"
                        ARCH="$(uname -m)"

                        case "$ARCH" in
                            x86_64|amd64)
                                ARCH='amd64'
                                ;;
                            arm64|aarch64)
                                ARCH='arm64'
                                ;;
                            *)
                                echo "[K8S] Unsupported kubectl architecture: $ARCH" >&2
                                exit 1
                                ;;
                        esac

                        VERSION="$(curl -fsSL https://dl.k8s.io/release/stable.txt)"
                        curl -fsSL -o "$BIN_DIR/kubectl" "https://dl.k8s.io/release/${VERSION}/bin/${OS}/${ARCH}/kubectl"
                        chmod +x "$BIN_DIR/kubectl"
                        printf '%s' "$BIN_DIR/kubectl"
                        ''',
                        returnStdout: true
                    ).trim()

                    def deployGateway = hasPathChange(['Dockerfile.gateway', 'src/', 'shared/'])
                    def deployAuth = hasPathChange(['services/auth-service/', 'shared/'])
                    def deployVitals = hasPathChange(['services/diagnostics-vitals-service/', 'shared/'])
                    def deployPatient = hasPathChange(['services/patient-registration-service/', 'shared/'])

                    withCredentials([
                        file(credentialsId: 'kubeconfig-coursework', variable: 'KUBECONFIG'),
                        string(credentialsId: 'jwt-secret', variable: 'JWT_SECRET_VALUE'),
                        string(credentialsId: 'mongodb-auth-uri', variable: 'AUTH_MONGODB_URI_VALUE'),
                        string(credentialsId: 'mongodb-vitals-uri', variable: 'VITALS_MONGODB_URI_VALUE'),
                        string(credentialsId: 'mongodb-patient-uri', variable: 'PATIENT_MONGODB_URI_VALUE'),
                        string(credentialsId: 'patient-id-hash-salt', variable: 'PATIENT_ID_HASH_SALT_VALUE'),
                    ]) {
                        withEnv([
                            "KUBECTL_CMD=${kubectlCmd}",
                            "DEPLOY_GATEWAY=${deployGateway.toString()}",
                            "DEPLOY_AUTH=${deployAuth.toString()}",
                            "DEPLOY_VITALS=${deployVitals.toString()}",
                            "DEPLOY_PATIENT=${deployPatient.toString()}"
                        ]) {
                            sh '''#!/bin/bash
                            set -euo pipefail

                            KUBECTL="$KUBECTL_CMD"

                            if [ ! -x "$KUBECTL" ]; then
                                echo '[K8S] kubectl is required but could not be prepared'
                                exit 1
                            fi

                            if [ -z "${KUBECONFIG:-}" ] || [ ! -f "$KUBECONFIG" ]; then
                                echo '[K8S] KUBECONFIG credential file is missing or unreadable'
                                exit 1
                            fi

                            k() {
                                "$KUBECTL" --kubeconfig "$KUBECONFIG" "$@"
                            }

                            if ! k cluster-info >/dev/null 2>&1; then
                                echo '[K8S] Unable to reach the Kubernetes cluster using the provided kubeconfig'
                                echo '[K8S] Current context:'
                                k config current-context || true
                                echo '[K8S] Configured API server:'
                                k config view --minify -o jsonpath='{.clusters[0].cluster.server}' || true
                                echo
                                exit 1
                            fi

                            k apply -f k8s/namespace.yaml

                            k -n "$K8S_NAMESPACE" create secret docker-registry "$K8S_REGISTRY_SECRET" \
                                --docker-server="$REGISTRY" \
                                --docker-username="$ACR_CREDS_USR" \
                                --docker-password="$ACR_CREDS_PSW" \
                                --dry-run=client -o yaml | k apply -f -

                            secret_args=(
                                --from-literal=JWT_SECRET="$JWT_SECRET_VALUE"
                                --from-literal=AUTH_MONGODB_URI="$AUTH_MONGODB_URI_VALUE"
                                --from-literal=VITALS_MONGODB_URI="$VITALS_MONGODB_URI_VALUE"
                                --from-literal=PATIENT_MONGODB_URI="$PATIENT_MONGODB_URI_VALUE"
                                --from-literal=PATIENT_ID_HASH_SALT="$PATIENT_ID_HASH_SALT_VALUE"
                            )

                            if [[ -n "${GOOGLE_CLIENT_ID:-}" ]]; then
                                secret_args+=(--from-literal=GOOGLE_CLIENT_ID="$GOOGLE_CLIENT_ID")
                            fi
                            if [[ -n "${GOOGLE_CLIENT_SECRET:-}" ]]; then
                                secret_args+=(--from-literal=GOOGLE_CLIENT_SECRET="$GOOGLE_CLIENT_SECRET")
                            fi
                            if [[ -n "${GOOGLE_CALLBACK_URL:-}" ]]; then
                                secret_args+=(--from-literal=GOOGLE_CALLBACK_URL="$GOOGLE_CALLBACK_URL")
                            fi
                            if [[ -n "${GOOGLE_REDIRECT_AFTER_LOGIN:-}" ]]; then
                                secret_args+=(--from-literal=GOOGLE_REDIRECT_AFTER_LOGIN="$GOOGLE_REDIRECT_AFTER_LOGIN")
                            fi

                            k -n "$K8S_NAMESPACE" create secret generic "$K8S_APP_SECRET_NAME" \
                                "${secret_args[@]}" \
                                --dry-run=client -o yaml | k apply -f -

                            k apply -f k8s/configmap.yaml
                            k apply -f k8s/services
                            k apply -f k8s/deployments

                            if [[ "$DEPLOY_GATEWAY" == 'true' ]]; then
                                k -n "$K8S_NAMESPACE" set image deployment/gateway gateway="$REGISTRY/gateway:$BUILD_NUMBER"
                            fi
                            if [[ "$DEPLOY_AUTH" == 'true' ]]; then
                                k -n "$K8S_NAMESPACE" set image deployment/auth-service auth-service="$REGISTRY/auth-service:$BUILD_NUMBER"
                            fi
                            if [[ "$DEPLOY_VITALS" == 'true' ]]; then
                                k -n "$K8S_NAMESPACE" set image deployment/vitals-service vitals-service="$REGISTRY/vitals-service:$BUILD_NUMBER"
                            fi
                            if [[ "$DEPLOY_PATIENT" == 'true' ]]; then
                                k -n "$K8S_NAMESPACE" set image deployment/patient-service patient-service="$REGISTRY/patient-service:$BUILD_NUMBER"
                            fi

                            k -n "$K8S_NAMESPACE" rollout status deployment/auth-service --timeout=180s
                            k -n "$K8S_NAMESPACE" rollout status deployment/vitals-service --timeout=180s
                            k -n "$K8S_NAMESPACE" rollout status deployment/patient-service --timeout=180s
                            k -n "$K8S_NAMESPACE" rollout status deployment/gateway --timeout=180s
                            '''
                        }
                    }
                }
            }
        }

        // --- STAGE: OWASP ZAP ---
        stage('OWASP ZAP Scan') {
            when {
                expression {
                    hasPathChange([
                        'Dockerfile.gateway',
                        'src/',
                        'shared/',
                        'services/auth-service/',
                        'services/diagnostics-vitals-service/',
                        'services/patient-registration-service/',
                        'k8s/',
                        'Jenkinsfile',
                        'jenkinsfile',
                    ])
                }
            }
            steps {
                script {
                    echo '[ZAP] Entered OWASP ZAP stage'
                    try {
                        def kubectlCmd = sh(
                            script: '''#!/bin/bash
                            set -euo pipefail

                            if command -v kubectl >/dev/null 2>&1; then
                                command -v kubectl
                                exit 0
                            fi

                            command -v curl >/dev/null 2>&1 || {
                                echo '[ZAP] curl is required to download kubectl' >&2
                                exit 1
                            }

                            BIN_DIR="$WORKSPACE/.jenkins/bin"
                            mkdir -p "$BIN_DIR"

                            OS="$(uname | tr '[:upper:]' '[:lower:]')"
                            ARCH="$(uname -m)"

                            case "$ARCH" in
                                x86_64|amd64)
                                    ARCH='amd64'
                                    ;;
                                arm64|aarch64)
                                    ARCH='arm64'
                                    ;;
                                *)
                                    echo "[ZAP] Unsupported kubectl architecture: $ARCH" >&2
                                    exit 1
                                    ;;
                            esac

                            VERSION="$(curl -fsSL https://dl.k8s.io/release/stable.txt)"
                            curl -fsSL -o "$BIN_DIR/kubectl" "https://dl.k8s.io/release/${VERSION}/bin/${OS}/${ARCH}/kubectl"
                            chmod +x "$BIN_DIR/kubectl"
                            printf '%s' "$BIN_DIR/kubectl"
                            ''',
                            returnStdout: true
                        ).trim()

                        withCredentials([
                            file(credentialsId: 'kubeconfig-coursework', variable: 'KUBECONFIG'),
                            string(credentialsId: 'ZAP_AUTH_EMAIL', variable: 'ZAP_MAIL'),
                            string(credentialsId: 'ZAP_AUTH_PASSWORD', variable: 'ZAP_PWD')
                        ]) 
                        {
                            echo '[ZAP] Credentials bound successfully'
                            sh 'mkdir -p reports/zap && chmod 777 reports/zap'
                            withEnv(["KUBECTL_CMD=${kubectlCmd}"]) 
                            {
                                def zapExitCode = sh(script: '''#!/bin/bash
                                    set -euo pipefail
                                    PF_PID=''
                                    cleanup() {
                                        rc=$?
                                        if [ -n "$PF_PID" ]; then
                                            kill "$PF_PID" >/dev/null 2>&1 || true
                                            wait "$PF_PID" 2>/dev/null || true
                                        fi
                                        if [ "$rc" -ne 0 ]; then
                                            echo "[ZAP] Failed at line ${LINENO} with exit code ${rc}"
                                        fi
                                        exit "$rc"
                                    }
                                    trap cleanup EXIT

                                    echo "[ZAP] Stage started"
                                    command -v curl >/dev/null 2>&1 || { echo "[ZAP] curl is required but not installed"; exit 1; }
                                    command -v node >/dev/null 2>&1 || { echo "[ZAP] node is required but not installed"; exit 1; }
                                    command -v docker >/dev/null 2>&1 || { echo "[ZAP] docker is required but not installed"; exit 1; }
                                    KUBECTL="$KUBECTL_CMD"
                                    [ -x "\$KUBECTL" ] || { echo "[ZAP] kubectl is required but could not be prepared"; exit 1; }
                                    [ -n "${KUBECONFIG:-}" ] && [ -f "$KUBECONFIG" ] || { echo "[ZAP] KUBECONFIG credential file is missing or unreadable"; exit 1; }

                                    k() {
                                        "$KUBECTL" --kubeconfig "$KUBECONFIG" "$@"
                                    }

                                    mkdir -p reports/zap
                                    rm -f reports/zap/zap-options.conf reports/zap/zap-report.json reports/zap/zap-report.html
                                    rm -f /tmp/coursework-port-forward.log /tmp/gateway-health.json
                                    ZAP_LOCAL_PORT=18080

                                    echo "[ZAP] Ensuring gateway deployment is ready"
                                    k -n coursework rollout status deployment/gateway --timeout=180s

                                    pkill -f "kubectl.*port-forward.*${ZAP_LOCAL_PORT}:80" >/dev/null 2>&1 || true

                                    echo "[ZAP] Starting gateway port-forward on 127.0.0.1:${ZAP_LOCAL_PORT}"
                                    k -n coursework port-forward svc/gateway ${ZAP_LOCAL_PORT}:80 >/tmp/coursework-port-forward.log 2>&1 &
                                    PF_PID=$!
                                    
                                    echo "[ZAP] Waiting for gateway..."
                                    GATEWAY_READY=0
                                    for _ in {1..24}; do
                                        if curl -fsS "http://127.0.0.1:${ZAP_LOCAL_PORT}/health" >/tmp/gateway-health.json; then
                                            if node -e "
                                                const fs = require('fs');
                                                const data = JSON.parse(fs.readFileSync('/tmp/gateway-health.json', 'utf8'));
                                                const backends = data.backends || {};
                                                const ready = backends.auth === 'up' && backends.patientRegistration === 'up' && backends.diagnosticsVitals === 'up';
                                                process.exit(ready ? 0 : 1);
                                            "; then
                                                GATEWAY_READY=1
                                                break
                                            fi
                                        fi
                                        sleep 5
                                    done

                                    if [ "$GATEWAY_READY" -ne 1 ]; then
                                        echo "[ZAP] Gateway health check failed after retries"
                                        cat /tmp/coursework-port-forward.log || true
                                        exit 10
                                    fi

                                    echo "[ZAP] Gateway health response:"
                                    cat /tmp/gateway-health.json || true

                                    echo "[ZAP] Waiting for auth login readiness..."
                                    ZAP_JWT=""
                                    LOGIN_RESPONSE=""
                                    ZAP_AUTH_PASSWORD="$ZAP_PWD"

                                    login_and_extract_token() {
                                        LOGIN_RESPONSE=$(curl -sS -X POST "http://127.0.0.1:${ZAP_LOCAL_PORT}/api/auth/login" \
                                            -H "Content-Type: application/json" \
                                            -d "{\\"email\\":\\"$ZAP_MAIL\\",\\"password\\":\\"$ZAP_AUTH_PASSWORD\\"}")

                                        ZAP_JWT=$(printf '%s' "$LOGIN_RESPONSE" | node -e "
                                            try {
                                                const data = JSON.parse(require('fs').readFileSync(0, 'utf8'));
                                                process.stdout.write(data.token || data.data?.token || '');
                                            } catch (_) {
                                                process.stdout.write('');
                                            }
                                        ")
                                    }

                                    for _ in {1..18}; do
                                        login_and_extract_token

                                        if [ -n "$ZAP_JWT" ]; then
                                            break
                                        fi

                                        if echo "$LOGIN_RESPONSE" | grep -qi "Invalid email or password"; then
                                            echo "[ZAP] Auth user missing; registering scan user..."

                                            REGISTER_RESPONSE=$(curl -sS -X POST "http://127.0.0.1:${ZAP_LOCAL_PORT}/api/auth/register" \
                                                -H "Content-Type: application/json" \
                                                -d "{\\"email\\":\\"$ZAP_MAIL\\",\\"password\\":\\"$ZAP_AUTH_PASSWORD\\",\\"firstName\\":\\"Zap\\",\\"lastName\\":\\"Scanner\\",\\"role\\":\\"clerk\\"}")

                                            if echo "$REGISTER_RESPONSE" | grep -qi "Password must contain at least one uppercase"; then
                                                ZAP_AUTH_PASSWORD='ZapScan@1234'
                                                REGISTER_RESPONSE=$(curl -sS -X POST "http://127.0.0.1:${ZAP_LOCAL_PORT}/api/auth/register" \
                                                    -H "Content-Type: application/json" \
                                                    -d "{\\"email\\":\\"$ZAP_MAIL\\",\\"password\\":\\"$ZAP_AUTH_PASSWORD\\",\\"firstName\\":\\"Zap\\",\\"lastName\\":\\"Scanner\\",\\"role\\":\\"clerk\\"}")
                                            fi

                                            if echo "$REGISTER_RESPONSE" | grep -qi "already exists"; then
                                                :
                                            fi

                                            login_and_extract_token
                                            if [ -n "$ZAP_JWT" ]; then
                                                break
                                            fi
                                        fi

                                        sleep 5
                                    done

                                    if [ -z "$ZAP_JWT" ]; then
                                        echo "[ZAP] Failed to get JWT"
                                        echo "[ZAP] Login response: $LOGIN_RESPONSE"
                                        k -n coursework logs deployment/auth-service --tail=200 || true
                                        exit 11
                                    fi

                                    echo "[ZAP] JWT acquired; running baseline scan"

                                    # Configure ZAP with the JWT
                                    printf "replacer.full_list(0).description=auth\\nreplacer.full_list(0).enabled=true\\nreplacer.full_list(0).matchtype=REQ_HEADER\\nreplacer.full_list(0).matchstr=Authorization\\nreplacer.full_list(0).regex=false\\nreplacer.full_list(0).replacement=Bearer %s" "$ZAP_JWT" > reports/zap/zap-options.conf

                                    ZAP_TARGET_URL="http://127.0.0.1:${ZAP_LOCAL_PORT}"
                                    ZAP_NETWORK_MODE="--network host"

                                    if [ "$(uname -s)" = "Darwin" ]; then
                                        ZAP_TARGET_URL="http://host.docker.internal:${ZAP_LOCAL_PORT}"
                                        ZAP_NETWORK_MODE=""
                                    fi

                                    echo "[ZAP] Running scan against ${ZAP_TARGET_URL}"

                                    set +e
                                    if [ -n "$ZAP_NETWORK_MODE" ]; then
                                        docker run --rm $ZAP_NETWORK_MODE \
                                            -v "$PWD/reports/zap:/zap/wrk:rw" \
                                            ghcr.io/zaproxy/zaproxy:stable zap-baseline.py \
                                            -t "$ZAP_TARGET_URL" -I -J zap-report.json -r zap-report.html \
                                            -z "-configfile /zap/wrk/zap-options.conf"
                                    else
                                        docker run --rm \
                                            -v "$PWD/reports/zap:/zap/wrk:rw" \
                                            ghcr.io/zaproxy/zaproxy:stable zap-baseline.py \
                                            -t "$ZAP_TARGET_URL" -I -J zap-report.json -r zap-report.html \
                                            -z "-configfile /zap/wrk/zap-options.conf"
                                    fi
                                    ZAP_RESULT=$?
                                    set -e

                                    echo "[ZAP] Baseline command exit code: $ZAP_RESULT"

                                    echo "[ZAP] Scan finished. Generated artifacts:"
                                    ls -l reports/zap || true

                                    if [ ! -f reports/zap/zap-report.json ] || [ ! -f reports/zap/zap-report.html ]; then
                                        echo "[ZAP] Expected report files were not generated"
                                        exit 12
                                    fi

                                    if [ "$ZAP_RESULT" -ne 0 ] && [ "$ZAP_RESULT" -ne 1 ] && [ "$ZAP_RESULT" -ne 2 ]; then
                                        echo "[ZAP] Baseline scan command failed with exit code: $ZAP_RESULT"
                                        exit "$ZAP_RESULT"
                                    fi

                                    echo "[ZAP] Inspecting report severities"

                                    set +e
                                    node -e 'const fs = require("fs");
                                    const report = JSON.parse(fs.readFileSync("reports/zap/zap-report.json", "utf8"));
                                    const sites = Array.isArray(report.site) ? report.site : (report.site ? [report.site] : []);
                                    const totals = { informational: 0, low: 0, medium: 0, high: 0 };
                                    for (const site of sites) {
                                        const alerts = Array.isArray(site.alerts) ? site.alerts : [];
                                        for (const alert of alerts) {
                                            const rawRiskCode = Object.prototype.hasOwnProperty.call(alert, "riskcode")
                                                ? alert.riskcode
                                                : (Object.prototype.hasOwnProperty.call(alert, "riskCode") ? alert.riskCode : -1);
                                            const riskCode = Number(rawRiskCode);
                                            const instanceCount = Number(alert.count || 0) || (Array.isArray(alert.instances) && alert.instances.length > 0 ? alert.instances.length : 1);
                                            if (riskCode === 0) {
                                                totals.informational += instanceCount;
                                            } else if (riskCode === 1) {
                                                totals.low += instanceCount;
                                            } else if (riskCode === 2) {
                                                totals.medium += instanceCount;
                                            } else if (riskCode === 3) {
                                                totals.high += instanceCount;
                                            }
                                        }
                                    }
                                    console.log("[ZAP] Alert summary -> High: " + totals.high + ", Medium: " + totals.medium + ", Low: " + totals.low + ", Informational: " + totals.informational);
                                    if (totals.high > 0) {
                                        process.exit(1);
                                    }
                                    if (totals.medium > 0 || totals.low > 0) {
                                        process.exit(2);
                                    }
                                    process.exit(0);'
                                    ZAP_RESULT=$?
                                    set -e

                                    exit "$ZAP_RESULT"
                                    ''', returnStatus: true)

                                echo "[ZAP] Shell execution completed with exit code: ${zapExitCode}"
                                sh 'ls -la reports || true'
                                sh 'ls -la reports/zap || true'

                                if (zapExitCode == 1) {
                                    error('[ZAP] High-risk alerts detected. Failing the pipeline.')
                                }

                                if (zapExitCode == 2) {
                                    unstable('[ZAP] Medium or low-risk alerts detected. Review the archived ZAP report.')
                                }

                                if (zapExitCode == 10) {
                                    error('[ZAP] Gateway did not become ready before the scan started.')
                                }

                                if (zapExitCode == 11) {
                                    error('[ZAP] Auth bootstrap failed. JWT could not be acquired for ZAP.')
                                }

                                if (zapExitCode == 12) {
                                    error('[ZAP] ZAP did not generate the expected HTML and JSON reports.')
                                }

                                if (zapExitCode != 0 && zapExitCode != 1 && zapExitCode != 2 && zapExitCode != 10 && zapExitCode != 11 && zapExitCode != 12) {
                                    error("[ZAP] Scan failed to complete correctly. Exit code: ${zapExitCode}")
                                }
                            }
                        }
                    } catch (Exception err) {
                        if (err.getMessage()?.contains('High-risk alerts detected') || err.getMessage()?.contains('Gateway did not become ready') || err.getMessage()?.contains('Auth bootstrap failed') || err.getMessage()?.contains('did not generate the expected HTML and JSON reports') || err.getMessage()?.contains('Scan failed to complete correctly')) {
                            throw err
                        }
                        echo "[ZAP] Jenkins-level failure before/during shell execution: ${err.getClass().getName()}"
                        echo "[ZAP] Message: ${err.getMessage()}"
                        unstable("[ZAP] Stage could not complete due to Jenkins configuration/runtime issue. Check [ZAP] Message above.")
                    }
                }
            }
            post {
                unsuccessful {
                    echo '[ZAP] OWASP stage unsuccessful. Open this stage log and search for [ZAP] entries.'
                }
            }
        }

        // --- STAGE: GITHUB RELEASE ---
        stage('GitHub Release') {
            // Only run this if the build was successful and at least one application image was rebuilt
            when {
                expression {
                    (currentBuild.result == null || currentBuild.result == 'SUCCESS') && applicationChanged()
                }
            }
            steps {
                script {
                    // 1. Define the Version (Using Build Number for uniqueness)
                    def releaseTag = "v1.0.${env.BUILD_NUMBER}"
                    
                    // 2. Create the Release on GitHub
                    createGitHubRelease(
                        credentialId: 'github-token-secret',
                        repository: 'HWDevOps-Group6/Coursework',
                        tag: releaseTag,
                        name: "Release ${releaseTag}",
                        commitish: 'main', 
                        bodyText: """
                        ## Healthcare Management System - Build ${env.BUILD_NUMBER}
                        
                        ### Deployment Images (Azure Container Registry)
                        The following images have been pushed to ACR:
                        - **Gateway:** `${env.REGISTRY}/gateway:${env.BUILD_NUMBER}`
                        - **Auth Service:** `${env.REGISTRY}/auth-service:${env.BUILD_NUMBER}`
                        - **Vitals Service:** `${env.REGISTRY}/vitals-service:${env.BUILD_NUMBER}`
                        - **Patient Service:** `${env.REGISTRY}/patient-service:${env.BUILD_NUMBER}`
                        
                        ### Kubernetes Deployment
                        - **Namespace:** `${env.K8S_NAMESPACE}`
                        - **Gateway Access:** deployed through the Kubernetes service `gateway`

                        ### Analysis & Quality
                        - **SonarCloud:** [View Results](https://sonarcloud.io/dashboard?id=HWDevOps-Group6_Coursework)
                        - **Status:** Verified, pushed to ACR, and deployed to Kubernetes
                        """
                    )
                }
            }
        }
    }

    post {
        always {
            sh "docker logout ${REGISTRY}"
            archiveArtifacts artifacts: 'services/auth-service/mochawesome-report/*', allowEmptyArchive: true
            archiveArtifacts artifacts: 'services/diagnostics-vitals-service/mochawesome-report/*', allowEmptyArchive: true
            archiveArtifacts artifacts: 'services/patient-registration-service/mochawesome-report/*', allowEmptyArchive: true
            archiveArtifacts artifacts: 'reports/zap/*', allowEmptyArchive: true
            cleanWs()
        }
    }
}