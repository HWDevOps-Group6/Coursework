def composeUp(serviceName) {
    sh """#!/bin/sh
    if command -v docker-compose >/dev/null 2>&1; then
        docker-compose up -d --no-deps ${serviceName}
    else
        docker compose up -d --no-deps ${serviceName}
    fi
    """
}

def composeUpForZap() {
    sh '''#!/bin/sh
    if command -v docker-compose >/dev/null 2>&1; then
        docker-compose up -d --build mongodb auth-service vitals-service patient-service gateway
    else
        docker compose up -d --build mongodb auth-service vitals-service patient-service gateway
    fi
    '''
}

pipeline {
    tools {
        nodejs 'NodeJS' 
    }
    agent any

    environment {
        REGISTRY = "hwudevopsregistry-e9a8dkdbanfebbhh.azurecr.io"
        ACR_CREDS = credentials('azure-reg-creds')
    }

    stages {
        stage('Login & Cleanup') {
            steps {
                sh '''#!/bin/sh
                printf '%s' "$ACR_CREDS_PSW" | docker login "$REGISTRY" -u "$ACR_CREDS_USR" --password-stdin
                '''
            }
        }

        // --- TEST: AUTH SERVICE ---
        stage('Test Auth Service') {
            when {
                anyOf {
                    changeset "services/auth-service/**"
                    changeset "shared/**"
                }
            }
            steps {
                catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                    dir('services/auth-service') {
                        sh 'npm install'
                        sh 'npm test'
                    }
                }
            }
            post {
                failure {
                    echo 'Auth Service tests failed! Check the logs above for details.'
                }
            }
        }

        // --- TEST: DIAGNOSTICS & VITALS ---
        stage('Test Diagnostics Service') {
            when {
                anyOf {
                    changeset "services/diagnostics-vitals-service/**"
                    changeset "shared/**"
                }
            }
            steps {
                catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                    dir('services/diagnostics-vitals-service') {
                        sh 'npm install'
                        sh 'npm test'
                    }
                }
            }
            post {
                failure {
                    echo 'Diagnostics Service tests failed! Check the logs above for details.'
                }
            }
        }

        // --- TEST: PATIENT REGISTRATION ---
        stage('Test Patient Service') {
            when {
                anyOf {
                    changeset "services/patient-registration-service/**"
                    changeset "shared/**"
                }
            }
            steps {
                catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                    dir('services/patient-registration-service') {
                        sh 'npm install'
                        sh 'npm test'
                    }
                }
            }
            post {
                failure {
                    echo 'Patient Service tests failed! Check the logs above for details.'
                }
            }
        }

        // --- STAGE: API GATEWAY ---
        stage('Build API Gateway') {
            when {
                anyOf {
                    changeset "Dockerfile.gateway"
                    changeset "src/**"
                    changeset "shared/**"
                }
            }
            steps {
                sh "docker build -f Dockerfile.gateway -t ${REGISTRY}/gateway:${env.BUILD_NUMBER} ."
                sh "docker push ${REGISTRY}/gateway:${env.BUILD_NUMBER}"
                composeUp('gateway')
            }
        }

        // --- STAGE: AUTH SERVICE ---
        stage('Build Auth Service') {
            when {
                anyOf {
                    changeset "services/auth-service/**"
                    changeset "shared/**"
                }
            }
            steps {
                sh "docker build -f services/auth-service/Dockerfile -t ${REGISTRY}/auth-service:${env.BUILD_NUMBER} ."
                sh "docker push ${REGISTRY}/auth-service:${env.BUILD_NUMBER}"
                composeUp('auth-service')
            }
        }

        // --- STAGE: DIAGNOSTICS & VITALS ---
        stage('Build Diagnostics Service') {
            when {
                anyOf {
                    changeset "services/diagnostics-vitals-service/**"
                    changeset "shared/**"
                }
            }
            steps {
                sh "docker build -f services/diagnostics-vitals-service/Dockerfile -t ${REGISTRY}/vitals-service:${env.BUILD_NUMBER} ."
                sh "docker push ${REGISTRY}/vitals-service:${env.BUILD_NUMBER}"
                composeUp('vitals-service')
            }
        }

        // --- STAGE: PATIENT REGISTRATION ---
        stage('Build Patient Service') {
            when {
                anyOf {
                    changeset "services/patient-registration-service/**"
                    changeset "shared/**"
                }
            }
            steps {
                sh "docker build -f services/patient-registration-service/Dockerfile -t ${REGISTRY}/patient-service:${env.BUILD_NUMBER} ."
                sh "docker push ${REGISTRY}/patient-service:${env.BUILD_NUMBER}"
                composeUp('patient-service')
            }
        }

        // --- STAGE: SONARCLOUD ---
        stage('SonarCloud Analysis') {
            steps {
                script {
                    dir('services/auth-service') {
                        sh 'npm install'
                        sh 'npm run test:coverage'
                    }
                    dir('services/diagnostics-vitals-service') {
                        sh 'npm install'
                        sh 'npm run test:coverage'
                    }
                    dir('services/patient-registration-service') {
                        sh 'npm install'
                        sh 'npm run test:coverage'
                    }

                    sh '''#!/bin/sh
                    set -e
                    test -f services/auth-service/coverage/lcov.info
                    test -f services/diagnostics-vitals-service/coverage/lcov.info
                    test -f services/patient-registration-service/coverage/lcov.info
                    ls -l services/auth-service/coverage/lcov.info
                    ls -l services/diagnostics-vitals-service/coverage/lcov.info
                    ls -l services/patient-registration-service/coverage/lcov.info
                    '''

                    def scannerHome = tool 'sonar-scanner'
                    withSonarQubeEnv('SonarCloud') {
                        sh """
                        ${scannerHome}/bin/sonar-scanner \
                        -Dsonar.projectBaseDir=${WORKSPACE} \
                        -Dsonar.organization=hwdevops-group6 \
                        -Dsonar.projectKey=HWDevOps-Group6_Coursework \
                        -Dsonar.projectName=healthcare-management-system \
                        -Dsonar.verbose=true \
                        -Dsonar.sources=src,shared,services/auth-service/src,services/diagnostics-vitals-service/server.js,services/diagnostics-vitals-service/config,services/diagnostics-vitals-service/middleware,services/diagnostics-vitals-service/models,services/diagnostics-vitals-service/services,services/patient-registration-service/src \
                        -Dsonar.tests=services/auth-service/test,services/diagnostics-vitals-service/test,services/patient-registration-service/test \
                        -Dsonar.exclusions=**/node_modules/**,**/mochawesome-report/**,**/coverage/**,**/.nyc_output/**,**/.dockerignore,**/build-wrapper-dump.json \
                        -Dsonar.javascript.lcov.reportPaths=${WORKSPACE}/services/auth-service/coverage/lcov.info,${WORKSPACE}/services/diagnostics-vitals-service/coverage/lcov.info,${WORKSPACE}/services/patient-registration-service/coverage/lcov.info
                        """
                    }
                }
            }
        }

        // --- STAGE: OWASP ZAP ---
        stage('OWASP ZAP Scan') {
            steps {
                script {
                    echo '[ZAP] Entered OWASP ZAP stage'
                    try {
                        echo '[ZAP] Starting application stack for scan'
                        composeUpForZap()

                        withCredentials([
                            string(credentialsId: 'ZAP_AUTH_EMAIL', variable: 'ZAP_MAIL'),
                            string(credentialsId: 'ZAP_AUTH_PASSWORD', variable: 'ZAP_PWD')
                        ]) {
                        echo '[ZAP] Credentials bound successfully'
                        sh 'mkdir -p reports/zap && chmod 777 reports/zap'
                        def zapExitCode = sh(script: '''#!/bin/bash
                    set -euo pipefail
                    trap 'rc=$?; echo "[ZAP] Failed at line ${LINENO} with exit code ${rc}"; exit ${rc}' ERR

                    if command -v docker-compose >/dev/null 2>&1; then
                        compose() {
                            docker-compose "$@"
                        }
                    else
                        compose() {
                            docker compose "$@"
                        }
                    fi

                    echo "[ZAP] Stage started"
                    command -v curl >/dev/null 2>&1 || { echo "[ZAP] curl is required but not installed"; exit 1; }
                    command -v node >/dev/null 2>&1 || { echo "[ZAP] node is required but not installed"; exit 1; }
                    command -v docker >/dev/null 2>&1 || { echo "[ZAP] docker is required but not installed"; exit 1; }

                    mkdir -p reports/zap
                    rm -f reports/zap/zap-options.conf reports/zap/zap-report.json reports/zap/zap-report.html
                    
                    echo "[ZAP] Waiting for gateway..."
                    GATEWAY_READY=0
                    for _ in {1..24}; do
                        if curl -fsS http://localhost/health >/tmp/gateway-health.json; then
                            if node -e "
                                const fs = require('fs');
                                const data = JSON.parse(fs.readFileSync('/tmp/gateway-health.json', 'utf8'));
                                const backends = data.backends || {};
                                const ready = backends.auth === 'up' && backends.patientRegistration === 'up' && backends.diagnosticsVitals === 'up';
                                process.exit(ready ? 0 : 1);
                            "; then
                                GATEWAY_READY=1
                                break
                            fi
                        fi
                        sleep 5
                    done

                    if [ "$GATEWAY_READY" -ne 1 ]; then
                        echo "[ZAP] Gateway health check failed after retries"
                        compose ps || true
                        GATEWAY_CONTAINER_ID="$(compose ps -q gateway || true)"
                        if [ -n "$GATEWAY_CONTAINER_ID" ]; then
                            echo "[ZAP] Gateway container logs:"
                            docker logs --tail 200 "$GATEWAY_CONTAINER_ID" || true
                        fi
                        exit 10
                    fi

                    echo "[ZAP] Gateway health response:"
                    cat /tmp/gateway-health.json || true

                    echo "[ZAP] Waiting for auth login readiness..."
                    ZAP_JWT=""
                    LOGIN_RESPONSE=""
                    ZAP_AUTH_PASSWORD="$ZAP_PWD"

                    login_and_extract_token() {
                        LOGIN_RESPONSE=$(curl -sS -X POST http://localhost/api/auth/login \
                            -H "Content-Type: application/json" \
                            -d "{\\"email\\":\\"$ZAP_MAIL\\",\\"password\\":\\"$ZAP_AUTH_PASSWORD\\"}")

                        ZAP_JWT=$(printf '%s' "$LOGIN_RESPONSE" | node -e "
                            try {
                                const data = JSON.parse(require('fs').readFileSync(0, 'utf8'));
                                process.stdout.write(data.token || data.data?.token || '');
                            } catch (_) {
                                process.stdout.write('');
                            }
                        ")
                    }

                    for _ in {1..18}; do
                        login_and_extract_token

                        if [ -n "$ZAP_JWT" ]; then
                            break
                        fi

                        if echo "$LOGIN_RESPONSE" | grep -qi "Invalid email or password"; then
                            echo "[ZAP] Auth user missing; registering scan user..."

                            REGISTER_RESPONSE=$(curl -sS -X POST http://localhost/api/auth/register \
                                -H "Content-Type: application/json" \
                                -d "{\\"email\\":\\"$ZAP_MAIL\\",\\"password\\":\\"$ZAP_AUTH_PASSWORD\\",\\"firstName\\":\\"Zap\\",\\"lastName\\":\\"Scanner\\",\\"role\\":\\"clerk\\"}")

                            if echo "$REGISTER_RESPONSE" | grep -qi "Password must contain at least one uppercase"; then
                                ZAP_AUTH_PASSWORD='ZapScan@1234'
                                REGISTER_RESPONSE=$(curl -sS -X POST http://localhost/api/auth/register \
                                    -H "Content-Type: application/json" \
                                    -d "{\\"email\\":\\"$ZAP_MAIL\\",\\"password\\":\\"$ZAP_AUTH_PASSWORD\\",\\"firstName\\":\\"Zap\\",\\"lastName\\":\\"Scanner\\",\\"role\\":\\"clerk\\"}")
                            fi

                            if echo "$REGISTER_RESPONSE" | grep -qi "already exists"; then
                                :
                            fi

                            login_and_extract_token
                            if [ -n "$ZAP_JWT" ]; then
                                break
                            fi
                        fi

                        sleep 5
                    done

                    if [ -z "$ZAP_JWT" ]; then
                        echo "[ZAP] Failed to get JWT"
                        echo "[ZAP] Login response: $LOGIN_RESPONSE"
                        AUTH_CONTAINER_ID="$(compose ps -q auth-service || true)"
                        if [ -n "$AUTH_CONTAINER_ID" ]; then
                            echo "[ZAP] Auth service logs:"
                            docker logs --tail 200 "$AUTH_CONTAINER_ID" || true
                        fi
                        exit 11
                    fi

                    echo "[ZAP] JWT acquired; running baseline scan"

                    # Configure ZAP with the JWT
                    printf "replacer.full_list(0).description=auth\\nreplacer.full_list(0).enabled=true\\nreplacer.full_list(0).matchtype=REQ_HEADER\\nreplacer.full_list(0).matchstr=Authorization\\nreplacer.full_list(0).regex=false\\nreplacer.full_list(0).replacement=Bearer %s" "$ZAP_JWT" > reports/zap/zap-options.conf

                    ZAP_TARGET_URL="http://localhost"
                    ZAP_NETWORK_MODE="--network host"

                    if [ "$(uname -s)" = "Darwin" ]; then
                        ZAP_TARGET_URL="http://host.docker.internal"
                        ZAP_NETWORK_MODE=""
                    fi

                    echo "[ZAP] Running scan against ${ZAP_TARGET_URL}"

                    set +e
                    if [ -n "$ZAP_NETWORK_MODE" ]; then
                        docker run --rm $ZAP_NETWORK_MODE \
                            -v "$PWD/reports/zap:/zap/wrk:rw" \
                            ghcr.io/zaproxy/zaproxy:stable zap-baseline.py \
                            -t "$ZAP_TARGET_URL" -I -J zap-report.json -r zap-report.html \
                            -z "-configfile /zap/wrk/zap-options.conf"
                    else
                        docker run --rm \
                            -v "$PWD/reports/zap:/zap/wrk:rw" \
                            ghcr.io/zaproxy/zaproxy:stable zap-baseline.py \
                            -t "$ZAP_TARGET_URL" -I -J zap-report.json -r zap-report.html \
                            -z "-configfile /zap/wrk/zap-options.conf"
                    fi
                    ZAP_RESULT=$?
                    set -e

                    echo "[ZAP] Scan finished. Generated artifacts:"
                    ls -l reports/zap || true

                    if [ ! -f reports/zap/zap-report.json ] || [ ! -f reports/zap/zap-report.html ]; then
                        echo "[ZAP] Expected report files were not generated"
                        exit 12
                    fi

                    if [ "$ZAP_RESULT" -ne 0 ] && [ "$ZAP_RESULT" -ne 1 ] && [ "$ZAP_RESULT" -ne 2 ]; then
                        echo "[ZAP] Baseline scan command failed with exit code: $ZAP_RESULT"
                        exit "$ZAP_RESULT"
                    fi

                    echo "[ZAP] Inspecting report severities"

                    set +e
                    node <<'NODE'
                    const fs = require('fs');

                    const report = JSON.parse(fs.readFileSync('reports/zap/zap-report.json', 'utf8'));
                    const alerts = (report.site || []).flatMap((site) => site.alerts || []);
                    const totals = {
                        informational: 0,
                        low: 0,
                        medium: 0,
                        high: 0
                    };

                    for (const alert of alerts) {
                        const riskCode = Number(alert.riskcode ?? alert.riskCode ?? -1);
                        const instanceCount = Number(alert.count || 0) || (Array.isArray(alert.instances) && alert.instances.length > 0 ? alert.instances.length : 1);

                        if (riskCode === 0) {
                            totals.informational += instanceCount;
                        } else if (riskCode === 1) {
                            totals.low += instanceCount;
                        } else if (riskCode === 2) {
                            totals.medium += instanceCount;
                        } else if (riskCode === 3) {
                            totals.high += instanceCount;
                        }
                    }

                    console.log(`[ZAP] Alert summary -> High: ${totals.high}, Medium: ${totals.medium}, Low: ${totals.low}, Informational: ${totals.informational}`);

                    if (totals.high > 0) {
                        process.exit(1);
                    }

                    if (totals.medium > 0 || totals.low > 0) {
                        process.exit(2);
                    }

                    process.exit(0);
                    NODE
                    ZAP_RESULT=$?
                    set -e

                    exit "$ZAP_RESULT"
                    ''', returnStatus: true)

                    echo "[ZAP] Shell execution completed with exit code: ${zapExitCode}"
                    sh 'ls -la reports || true'
                    sh 'ls -la reports/zap || true'

                    if (zapExitCode == 1) {
                        error('[ZAP] High-risk alerts detected. Failing the pipeline.')
                    }

                    if (zapExitCode == 2) {
                        unstable('[ZAP] Medium or low-risk alerts detected. Review the archived ZAP report.')
                    }

                    if (zapExitCode == 10) {
                        error('[ZAP] Gateway did not become ready before the scan started.')
                    }

                    if (zapExitCode == 11) {
                        error('[ZAP] Auth bootstrap failed. JWT could not be acquired for ZAP.')
                    }

                    if (zapExitCode == 12) {
                        error('[ZAP] ZAP did not generate the expected HTML and JSON reports.')
                    }

                    if (zapExitCode != 0 && zapExitCode != 1 && zapExitCode != 2 && zapExitCode != 10 && zapExitCode != 11 && zapExitCode != 12) {
                        error("[ZAP] Scan failed to complete correctly. Exit code: ${zapExitCode}")
                    }
                        }
                    } catch (Exception err) {
                        if (err.getMessage()?.contains('High-risk alerts detected') || err.getMessage()?.contains('Gateway did not become ready') || err.getMessage()?.contains('Auth bootstrap failed') || err.getMessage()?.contains('did not generate the expected HTML and JSON reports') || err.getMessage()?.contains('Scan failed to complete correctly')) {
                            throw err
                        }
                        echo "[ZAP] Jenkins-level failure before/during shell execution: ${err.getClass().getName()}"
                        echo "[ZAP] Message: ${err.getMessage()}"
                        unstable("[ZAP] Stage could not complete due to Jenkins configuration/runtime issue. Check [ZAP] Message above.")
                    }
                }
            }
            post {
                unsuccessful {
                    echo '[ZAP] OWASP stage unsuccessful. Open this stage log and search for [ZAP] entries.'
                }
            }
        }

        // --- STAGE: GITHUB RELEASE ---
        stage('GitHub Release') {
            // Only run this if the build was successful
            when {
                expression { currentBuild.result == null || currentBuild.result == 'SUCCESS' }
            }
            steps {
                script {
                    // 1. Define the Version (Using Build Number for uniqueness)
                    def releaseTag = "v1.0.${env.BUILD_NUMBER}"
                    
                    // 2. Create the Release on GitHub
                    createGitHubRelease(
                        credentialId: 'github-token-secret',
                        repository: 'HWDevOps-Group6/Coursework',
                        tag: releaseTag,
                        name: "Release ${releaseTag}",
                        commitish: 'main', 
                        bodyText: """
                        ## Healthcare Management System - Build ${env.BUILD_NUMBER}
                        
                        ### Deployment Images (Azure Container Registry)
                        The following images have been pushed to ACR:
                        - **Gateway:** `${env.REGISTRY}/gateway:${env.BUILD_NUMBER}`
                        - **Auth Service:** `${env.REGISTRY}/auth-service:${env.BUILD_NUMBER}`
                        - **Vitals Service:** `${env.REGISTRY}/vitals-service:${env.BUILD_NUMBER}`
                        - **Patient Service:** `${env.REGISTRY}/patient-service:${env.BUILD_NUMBER}`
                        
                        ### Analysis & Quality
                        - **SonarCloud:** [View Results](https://sonarcloud.io/dashboard?id=HWDevOps-Group6_Coursework)
                        - **Status:** Verified and Pushed to Production
                        """
                    )
                }
            }
        }
    }

    post {
        always {
            sh "docker logout ${REGISTRY}"
            archiveArtifacts artifacts: 'services/auth-service/mochawesome-report/*', allowEmptyArchive: true
            archiveArtifacts artifacts: 'services/diagnostics-vitals-service/mochawesome-report/*', allowEmptyArchive: true
            archiveArtifacts artifacts: 'services/patient-registration-service/mochawesome-report/*', allowEmptyArchive: true
            archiveArtifacts artifacts: 'reports/zap/*', allowEmptyArchive: true
            cleanWs()
        }
    }
}