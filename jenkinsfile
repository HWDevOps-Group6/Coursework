def composeUp(serviceName) {
    sh """#!/bin/sh
    if command -v docker-compose >/dev/null 2>&1; then
        docker-compose up -d --no-deps ${serviceName}
    else
        docker compose up -d --no-deps ${serviceName}
    fi
    """
}

pipeline {
    tools {
        nodejs 'NodeJS' 
    }
    agent any

    environment {
        REGISTRY = "hwudevopsregistry-e9a8dkdbanfebbhh.azurecr.io"
        ACR_CREDS = credentials('azure-reg-creds')
    }

    stages {
        stage('Login & Setup') {
            steps {
                sh '''#!/bin/sh
                printf '%s' "$ACR_CREDS_PSW" | docker login "$REGISTRY" -u "$ACR_CREDS_USR" --password-stdin
                mkdir -p reports/zap
                '''
            }
        }

        // --- 1. TEST STAGE (FAIL FAST) ---
        stage('Unit Tests') {
            steps {
                script {
                    def services = [
                        'auth': 'services/auth-service',
                        'vitals': 'services/diagnostics-vitals-service',
                        'patient': 'services/patient-registration-service'
                    ]

                    services.each { name, dirPath ->
                        echo "Testing ${name}..."
                        dir(dirPath) {
                            sh 'npm install'
                            sh 'npm test'
                        }
                    }
                }
            }
        }

        // --- 2. QUALITY GATE ---
        stage('SonarCloud Analysis') {
            steps {
                script {
                    // Generate coverage for all services
                    dir('services/auth-service') { sh 'npm run test:coverage || true' }
                    dir('services/diagnostics-vitals-service') { sh 'npm run test:coverage || true' }
                    dir('services/patient-registration-service') { sh 'npm run test:coverage || true' }

                    def scannerHome = tool 'sonar-scanner'
                    withSonarQubeEnv('SonarCloud') {
                        sh """
                        ${scannerHome}/bin/sonar-scanner \
                        -Dsonar.projectBaseDir=${WORKSPACE} \
                        -Dsonar.organization=hwdevops-group6 \
                        -Dsonar.projectKey=HWDevOps-Group6_Coursework \
                        -Dsonar.projectName=healthcare-management-system \
                        -Dsonar.sources=src,shared,services/auth-service/src,services/diagnostics-vitals-service/server.js,services/patient-registration-service/src \
                        -Dsonar.tests=services/auth-service/test,services/diagnostics-vitals-service/test,services/patient-registration-service/test \
                        -Dsonar.exclusions=**/node_modules/**,**/coverage/** \
                        -Dsonar.javascript.lcov.reportPaths=services/auth-service/coverage/lcov.info,services/diagnostics-vitals-service/coverage/lcov.info,services/patient-registration-service/coverage/lcov.info
                        """
                    }
                }
            }
        }

        // --- 3. BUILD & DEPLOY TO STAGING ---
        stage('Build & Push Images') {
            steps {
                script {
                    // Define map of [ServiceName: DockerfilePath]
                    def builds = [
                        'auth-service': 'services/auth-service/Dockerfile',
                        'vitals-service': 'services/diagnostics-vitals-service/Dockerfile',
                        'patient-service': 'services/patient-registration-service/Dockerfile',
                        'gateway': 'Dockerfile.gateway'
                    ]

                    builds.each { service, df ->
                        sh "docker build -f ${df} -t ${REGISTRY}/${service}:${env.BUILD_NUMBER} ."
                        sh "docker push ${REGISTRY}/${service}:${env.BUILD_NUMBER}"
                        // Deploy locally for ZAP scanning
                        composeUp(service)
                    }
                }
            }
        }

        // --- 4. DYNAMIC SECURITY SCAN (DAST) ---
        stage('OWASP ZAP Scan') {
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'zap-auth-credentials', usernameVariable: 'ZAP_MAIL', passwordVariable: 'ZAP_PWD')
                ]) {
                    sh '''#!/bin/bash
                    set -euo pipefail
                    
                    echo "Waiting for gateway..."
                    timeout 60s bash -c 'until curl -fs http://localhost/health; do sleep 5; done'

                    echo "Waiting for auth login readiness..."
                    ZAP_JWT=""
                    LOGIN_RESPONSE=""
                    ZAP_AUTH_PASSWORD="$ZAP_PWD"

                    login_and_extract_token() {
                        LOGIN_RESPONSE=$(curl -sS -X POST http://localhost/api/auth/login \
                            -H "Content-Type: application/json" \
                            -d "{\\"email\\":\\"$ZAP_MAIL\\",\\"password\\":\\"$ZAP_AUTH_PASSWORD\\"}")

                        ZAP_JWT=$(printf '%s' "$LOGIN_RESPONSE" | node -e "
                            try {
                                const data = JSON.parse(require('fs').readFileSync(0, 'utf8'));
                                process.stdout.write(data.token || data.data?.token || '');
                            } catch (_) {
                                process.stdout.write('');
                            }
                        ")
                    }

                    for _ in {1..18}; do
                        login_and_extract_token

                        if [ -n "$ZAP_JWT" ]; then
                            break
                        fi

                        if echo "$LOGIN_RESPONSE" | grep -qi "Invalid email or password"; then
                            echo "Auth user missing; registering scan user..."

                            REGISTER_RESPONSE=$(curl -sS -X POST http://localhost/api/auth/register \
                                -H "Content-Type: application/json" \
                                -d "{\\"email\\":\\"$ZAP_MAIL\\",\\"password\\":\\"$ZAP_AUTH_PASSWORD\\",\\"firstName\\":\\"Zap\\",\\"lastName\\":\\"Scanner\\",\\"role\\":\\"clerk\\"}")

                            if echo "$REGISTER_RESPONSE" | grep -qi "Password must contain at least one uppercase"; then
                                ZAP_AUTH_PASSWORD='ZapScan@1234'
                                REGISTER_RESPONSE=$(curl -sS -X POST http://localhost/api/auth/register \
                                    -H "Content-Type: application/json" \
                                    -d "{\\"email\\":\\"$ZAP_MAIL\\",\\"password\\":\\"$ZAP_AUTH_PASSWORD\\",\\"firstName\\":\\"Zap\\",\\"lastName\\":\\"Scanner\\",\\"role\\":\\"clerk\\"}")
                            fi

                            if echo "$REGISTER_RESPONSE" | grep -qi "already exists"; then
                                :
                            fi

                            login_and_extract_token
                            if [ -n "$ZAP_JWT" ]; then
                                break
                            fi
                        fi

                        sleep 5
                    done

                    if [ -z "$ZAP_JWT" ]; then
                        echo "Failed to get JWT"
                        echo "Login response: $LOGIN_RESPONSE"
                        exit 1
                    fi

                    # Configure ZAP with the JWT
                    printf "replacer.full_list(0).description=auth\\nreplacer.full_list(0).enabled=true\\nreplacer.full_list(0).matchtype=REQ_HEADER\\nreplacer.full_list(0).matchstr=Authorization\\nreplacer.full_list(0).regex=false\\nreplacer.full_list(0).replacement=Bearer %s" "$ZAP_JWT" > reports/zap/zap-options.conf

                    docker run --rm --network host \
                        -v "$PWD/reports/zap:/zap/wrk:rw" \
                        ghcr.io/zaproxy/zaproxy:stable zap-baseline.py \
                        -t http://localhost -J zap-report.json -r zap-report.html \
                        -z "-configfile /zap/wrk/zap-options.conf" || true
                    '''
                }
            }
        }

        stage('GitHub Release') {
            when { expression { currentBuild.result == null || currentBuild.result == 'SUCCESS' } }
            steps {
                script {
                    def releaseTag = "v1.0.${env.BUILD_NUMBER}"
                    // Note: Ensure createGitHubRelease is defined in your Shared Library
                    createGitHubRelease(
                        credentialId: 'github-token-secret',
                        repository: 'HWDevOps-Group6/Coursework',
                        tag: releaseTag,
                        name: "Release ${releaseTag}",
                        bodyText: "Verified build ${env.BUILD_NUMBER} pushed to ACR."
                    )
                }
            }
        }
    }

    post {
        always {
            sh "docker logout ${REGISTRY} || true"
            archiveArtifacts artifacts: 'services/auth-service/mochawesome-report/*', allowEmptyArchive: true
            archiveArtifacts artifacts: 'services/diagnostics-vitals-service/mochawesome-report/*', allowEmptyArchive: true
            archiveArtifacts artifacts: 'services/patient-registration-service/mochawesome-report/*', allowEmptyArchive: true
            archiveArtifacts artifacts: 'reports/zap/*', allowEmptyArchive: true
            cleanWs()
        }
    }
}